{
  "name": "teampresence-slack",
  "version": "1.0.0",
  "private": true,
  "description": "Slack app: presence / away updates and meeting roll calls for any domain",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "demo": "bash scripts/demo-start.sh",
    "tunnel": "bash scripts/tunnel-watchdog.sh",
    "demo:snapshot": "node scripts/build-demo-snapshot.mjs",
    "demo:sanitize": "node scripts/sanitize-demo.mjs",
    "demo:build": "node scripts/build-demo.mjs --mock",
    "demo:build:live": "node scripts/build-demo.mjs",
    "demo:serve": "node scripts/serve-demo.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@slack/bolt": "^3.22.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "openid-client": "^6.8.3"
  }
}
