# Slack app credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Dev without public HTTPS: set SLACK_SOCKET_MODE=true and create an App-Level Token with connections:write
# SLACK_SOCKET_MODE=true
# SLACK_APP_TOKEN=xapp-your-app-token

# Optional: comma-separated Slack user IDs who can start roll calls and run admin reports
# (If empty, anyone in the workspace can use admin commands — fine for small teams only.)
TEAMPRESENCE_ADMIN_USER_IDS=U01234567,U07654321

# Public base URL of this service (no trailing slash). Used in Slack interactivity URLs if you add OAuth later.
# Example: https://presence.example.com
PUBLIC_URL=https://your-domain.example

# SQLite path (default: ./data/teampresence.db)
DATABASE_PATH=./data/teampresence.db

# Optional: default channel ID for daily digest (C...)
# TEAMPRESENCE_DIGEST_CHANNEL_ID=

# ---- Team Presence model (NEW) ----
#
# Controls where the Team Presence widget gets its data from.
#
#   bot             (default) — SQLite check-ins + /teampresence
#                   commands. Backwards-compatible with the original
#                   demo. No extra env vars required.
#
#   slack           — pulls status_text / status_emoji / auto-presence
#                   from Slack for every roster member and maps to a
#                   bucket (available/wfh/meeting/away/vacation/unknown)
#                   via src/presence/mapping.js. "Accuracy comes from
#                   your Slack status." Requires `users:read`,
#                   `users.profile:read`, and `users:read.presence`
#                   bot scopes.
#
#   slack+workday   — slack mode + a Workday vacation overlay. Workday
#                   wins for full-day OOO; Slack wins for in-the-moment
#                   whereabouts. Workday provider is chosen below.
#
# When the model is anything other than `bot`, the /teampresence
# bot commands respond with a deprecation notice pointing users at
# their Slack status. Flip back to `bot` to restore them instantly.
# PRESENCE_MODEL=bot

# ---- Workday provider (used only when PRESENCE_MODEL=slack+workday) ----
#
# See WORKDAY.md for the full playbook. TL;DR:
#
#   none  (default) — inert. Dashboard runs without Workday data.
#   csv             — read absences from a local CSV (WORKDAY_CSV_PATH).
#                     Re-read every 5 min. Best stopgap until IT confirms
#                     the Workday endpoint. Sample schema is shipped at
#                     data/workday-absences.example.csv — copy, edit,
#                     point WORKDAY_CSV_PATH at it.
#   ical            — read a shared iCal feed (Workday, Outlook, Google
#                     Calendar — anything RFC 5545). Matched to the
#                     roster by ATTENDEE email. Optional type map:
#                     WORKDAY_ICAL_TYPE_MAP=Sick=*Sick*, Holiday=*Holiday*, PTO=*
#   rest            — JSON endpoint. Response shape documented in
#                     src/presence/workday.js; override with transform()
#                     in code if IT's shape differs.
#
# WORKDAY_PROVIDER=none
#
# --- CSV ---
# WORKDAY_CSV_PATH=./data/workday-absences.csv
#
# --- iCal ---
# WORKDAY_ICAL_URL=
# WORKDAY_ICAL_TYPE_MAP=Sick=*Sick*, Holiday=*Holiday*, PTO=*
#
# --- REST ---
# WORKDAY_ENDPOINT=
# WORKDAY_TOKEN=
# WORKDAY_REST_HEADERS={"X-Org-Id":"email-norton"}

# ---- EMAIL NORTON dashboard ----

# Brand name shown in the dashboard header and some Slack responses.
BRAND_NAME=EMAIL NORTON

# IANA timezone used to compute "today" for daily check-ins.
TEAM_TIMEZONE=Europe/Prague

# Slack channel ID that receives exception alerts (late / sick / pto / away / ooo / rollcall late/absent).
# Invite the bot to this channel. Leave empty to disable alerts.
# BOSS_CHANNEL_ID=C0123456789

# Shared secret required to view the web dashboard at /?key=…
# Leave empty ONLY for local dev.
# DASHBOARD_KEY=change-me-to-something-long

# Optional: comma-separated Slack user IDs that should always appear on the dashboard
# even before anyone has used a slash command.
# TEAM_MEMBER_IDS=U01234567,U07654321

# ---- Role gating for dashboard widgets (v1) ----
# Each user's roles = the union of lists they appear in. Widgets declare which
# roles may see them (manifest in src/widgets.js).
# ROLE_EMAIL_USER_IDS=U01234567,U07654321
# ROLE_CSM_USER_IDS=
# ROLE_MANAGER_USER_IDS=
# ROLE_DEV_USER_IDS=
# ROLE_TARGETING_USER_IDS=

# ================================================================
# Jira configuration
# ----------------------------------------------------------------
# EMAIL NORTON runs two Jira projects in parallel:
#   - EMOPS    (current / primary)
#   - EMAILCO  (older / legacy)
# Both have meaningfully different filters per widget, so every
# widget env var can be scoped per-project using the pattern
#   JIRA_<PROJECT>_<WIDGET>_JQL=…
# A "combined view" (directors) is supported via the reserved
# JIRA_ALL_<WIDGET>_JQL slot.
#
# If JIRA_PROJECT_KEYS is not set the dashboard still works —
# widgets fall back to the legacy single-project env vars at the
# bottom of this file (JIRA_THROUGHPUT_JQL, …). Use that mode for
# single-project deployments.
# ================================================================

# Corp Jira base URL — must be reachable from wherever this service runs.
# JIRA_BASE_URL=https://jira.corp.nortonlifelock.com

# Personal Access Token (Jira Data Center / Server). Create at
# Profile → Personal Access Tokens. Read-only is fine. Paste via the
# helper script (never in chat): ./scripts/set-jira-token.sh
# JIRA_TOKEN=

# ---- Project switcher (multi-project mode) ----
# Comma-separated project keys. First one is the default shown on
# page load (override with JIRA_DEFAULT_PROJECT).
# JIRA_PROJECT_KEYS=EMOPS,EMAILCO
# JIRA_PROJECT_LABELS=EMOPS (current),EMAILCO (legacy)
# JIRA_DEFAULT_PROJECT=EMOPS
# Show a "Both" tab that uses JIRA_ALL_* queries. Default: on when
# there are 2+ keys. Set to "0" to hide.
# JIRA_PROJECT_ALLOW_COMBINED=1
# JIRA_ALL_LABEL=Both

# Slack channel ID that receives the Monday 08:00 Europe/Prague throughput post.
# Invite the bot to this channel.
# REPORTS_CHANNEL_ID=C0123456789

# ================================================================
# Per-project JQL — the 10 widgets × 2 projects
# ----------------------------------------------------------------
# Scaffolded with sensible defaults. Your scrum master should
# tune these against real Jira until the numbers match what the
# team expects (see REAL-DATA-CHECKLIST.md).
# ================================================================

# ---- Weekly throughput ("issues resolved last week") ----
# Builder injects resolved >= <startOfWeek> AND resolved < <endOfWeek>.
# JIRA_EMOPS_THROUGHPUT_JQL=project = EMOPS AND statusCategory = Done
# JIRA_EMAILCO_THROUGHPUT_JQL=project = EMAILCO AND statusCategory = Done
# JIRA_ALL_THROUGHPUT_JQL=project in (EMOPS, EMAILCO) AND statusCategory = Done

# ---- Backlog overview ("all open right now") ----
# Per-priority + per-age sub-queries are layered on top.
# JIRA_EMOPS_BACKLOG_JQL=project = EMOPS AND statusCategory != Done
# JIRA_EMAILCO_BACKLOG_JQL=project = EMAILCO AND statusCategory != Done
# JIRA_ALL_BACKLOG_JQL=project in (EMOPS, EMAILCO) AND statusCategory != Done

# ---- Ticket lifecycle (median/mean/p95 resolution time) ----
# JIRA_EMOPS_LIFECYCLE_JQL=project = EMOPS AND statusCategory = Done AND resolved >= -30d
# JIRA_EMAILCO_LIFECYCLE_JQL=project = EMAILCO AND statusCategory = Done AND resolved >= -30d
# Previous window (optional — drives delta-vs-prev badge):
# JIRA_EMOPS_LIFECYCLE_PREV_JQL=project = EMOPS AND statusCategory = Done AND resolved >= -60d AND resolved < -30d
# JIRA_EMAILCO_LIFECYCLE_PREV_JQL=project = EMAILCO AND statusCategory = Done AND resolved >= -60d AND resolved < -30d
# Lookback window for the summary copy (days):
# JIRA_EMOPS_LIFECYCLE_LOOKBACK_DAYS=30
# JIRA_EMAILCO_LIFECYCLE_LOOKBACK_DAYS=30

# ---- Inflow vs resolved (time-series) ----
# Defaults to the THROUGHPUT JQL base; override if inflow scope differs.
# JIRA_EMOPS_INFLOW_JQL=project = EMOPS
# JIRA_EMAILCO_INFLOW_JQL=project = EMAILCO

# ---- SLA / aging risk ----
# Defaults to BACKLOG_JQL; override to narrow to "critical path" only.
# JIRA_EMOPS_SLA_JQL=project = EMOPS AND statusCategory != Done AND priority in (Highest, Critical, High)
# JIRA_EMAILCO_SLA_JQL=project = EMAILCO AND statusCategory != Done AND priority in (Highest, Critical, High)
# Shared across projects: thresholds (days) for the "warn" / "breach" tiers.
# JIRA_SLA_THRESHOLDS=Highest:3,Critical:5,High:10,Medium:20,Low:45

# ---- Kanban snapshot ----
# Board JQL — should return the currently-visible cards
# (typically "not Done" + ORDER BY Rank).
# JIRA_EMOPS_KANBAN_JQL=project = EMOPS AND resolution = Unresolved ORDER BY Rank
# JIRA_EMAILCO_KANBAN_JQL=project = EMAILCO AND resolution = Unresolved ORDER BY Rank
# Optional per-project column order (comma-separated status names):
# JIRA_EMOPS_KANBAN_COLUMNS=To Do,In Progress,In Review,Done
# JIRA_EMAILCO_KANBAN_COLUMNS=Open,In Progress,Resolved
# Optional per-project board URL for the "Open in Jira" link:
# JIRA_EMOPS_KANBAN_URL=https://jira.corp.nortonlifelock.com/secure/RapidBoard.jspa?rapidView=101032
# JIRA_EMAILCO_KANBAN_URL=https://jira.corp.nortonlifelock.com/secure/RapidBoard.jspa?rapidView=…

# ---- Top priority tickets ("what's on fire right now") ----
# Defaults to KANBAN_JQL; narrow here if the "To Do" column contains
# a mix of priorities and you want to scope to the top of the pile.
# JIRA_EMOPS_TOP_PRIORITY_JQL=project = EMOPS AND resolution = Unresolved
# JIRA_EMAILCO_TOP_PRIORITY_JQL=project = EMAILCO AND resolution = Unresolved
# Which priorities count as "top" (comma-separated):
# JIRA_EMOPS_TOP_PRIORITIES=Highest,Critical,High
# JIRA_EMAILCO_TOP_PRIORITIES=Highest,Critical,High
# Which status gets reported (exact string from Jira):
# JIRA_EMOPS_TOP_PRIORITY_STATUS=To Do
# JIRA_EMAILCO_TOP_PRIORITY_STATUS=Open
# How many tickets to show:
# JIRA_EMOPS_TOP_PRIORITY_LIMIT=6
# JIRA_EMAILCO_TOP_PRIORITY_LIMIT=6

# ---- Sprint backlog ("what's queued next") ----
# Defaults to KANBAN_JQL + status=TOP_PRIORITY_STATUS.
# JIRA_EMOPS_SPRINT_BACKLOG_JQL=project = EMOPS AND sprint in openSprints()
# JIRA_EMAILCO_SPRINT_BACKLOG_JQL=project = EMAILCO AND resolution = Unresolved
# JIRA_EMOPS_SPRINT_BACKLOG_STATUS=To Do
# JIRA_EMAILCO_SPRINT_BACKLOG_STATUS=Open

# ---- Reopen / escalation rate ----
# JIRA_EMOPS_REOPEN_JQL=project = EMOPS
# JIRA_EMAILCO_REOPEN_JQL=project = EMAILCO
# Which statuses count as "done" when detecting reopens (comma list):
# JIRA_EMOPS_DONE_STATUSES=Done,Closed,Resolved
# JIRA_EMAILCO_DONE_STATUSES=Resolved,Closed
# Window (days) to look back for reopen events:
# JIRA_EMOPS_REOPEN_WINDOW_DAYS=30
# JIRA_EMAILCO_REOPEN_WINDOW_DAYS=30

# ---- Team throughput leaderboard ("who closed the most") ----
# Reuses THROUGHPUT by default; override here if leaderboard scope differs.
# JIRA_EMOPS_LEADERBOARD_JQL=project = EMOPS AND statusCategory = Done
# JIRA_EMAILCO_LEADERBOARD_JQL=project = EMAILCO AND statusCategory = Done
# JIRA_EMOPS_LEADERBOARD_LIMIT=6
# JIRA_EMAILCO_LEADERBOARD_LIMIT=6

# ================================================================
# Legacy single-project env vars (used only when JIRA_PROJECT_KEYS
# is NOT set, or as a last-resort fallback when a per-project var
# is missing). You can ignore this whole block once the per-project
# vars above are filled in.
# ================================================================
# JIRA_THROUGHPUT_JQL=
# JIRA_BACKLOG_JQL=
# JIRA_LIFECYCLE_JQL=
# JIRA_LIFECYCLE_PREV_JQL=
# JIRA_LIFECYCLE_LOOKBACK_DAYS=30
# JIRA_INFLOW_JQL=
# JIRA_SLA_JQL=
# JIRA_KANBAN_JQL=
# JIRA_KANBAN_COLUMNS=
# JIRA_KANBAN_URL=
# JIRA_TOP_PRIORITY_JQL=
# JIRA_TOP_PRIORITIES=Highest,Critical,High
# JIRA_TOP_PRIORITY_STATUS=To Do
# JIRA_TOP_PRIORITY_LIMIT=6
# JIRA_SPRINT_BACKLOG_JQL=
# JIRA_SPRINT_BACKLOG_STATUS=To Do
# JIRA_REOPEN_JQL=
# JIRA_DONE_STATUSES=Done,Closed,Resolved
# JIRA_REOPEN_WINDOW_DAYS=30
# JIRA_LEADERBOARD_JQL=
# JIRA_LEADERBOARD_LIMIT=6

# =====================================================================
# Authentication
# =====================================================================
#
# AUTH_STRATEGY selects how the dashboard verifies users:
#
#   shared-key (default) — the long-standing DASHBOARD_KEY ?key=... flow.
#                          Everyone in the team has the same key; fine
#                          for the pilot, not fine for a wider audience.
#
#   oidc                 — Azure AD SSO via OIDC + PKCE. When enabled,
#                          requires the OIDC_* vars below AND an app
#                          registration in the Gen Digital Azure tenant
#                          (see AZURE-AD-ADMIN-REQUEST.md for the
#                          hand-off template).
#
# Missing/typoed OIDC config does NOT crash the server — it logs an
# [auth] warning and stays on shared-key. Makes rollout safe.
# =====================================================================
# AUTH_STRATEGY=oidc

# Azure AD app registration details (get from identity team).
# See AZURE-AD-ADMIN-REQUEST.md for the email template to request these.
# OIDC_TENANT_ID=<azure-ad-tenant-guid>
# OIDC_CLIENT_ID=<app-registration-guid>
# OIDC_CLIENT_SECRET=<app-registration-client-secret-value>

# Where Azure sends the user after they sign in. MUST be registered in
# the Azure app as a Web redirect URI. Use http://localhost:3000/auth/callback
# for local dev, plus the real corporate hostname for staging / prod.
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Random secret used to sign our own session cookie (HS256). Generate
# with:  openssl rand -hex 32
# MUST be >= 32 chars. Rotating this invalidates all sessions — users
# sign in again. The scripts/set-oidc-credentials.sh helper rotates
# this on every run by design.
# OIDC_SESSION_SECRET=<64-hex-chars>

# How long a signed-in session lasts before requiring re-auth.
# Default 480 (8 hours). Minimum enforced: 1 minute.
# OIDC_SESSION_TTL_MINUTES=480

# Cookie name. Default: gp_session. Only change if another app on the
# same host already uses gp_session for something else.
# OIDC_SESSION_COOKIE=gp_session

# When OIDC is on, also accept shared-key auth for non-browser callers
# (curl scripts, Slack slash commands, the Cloudflare demo tunnel).
# Recommended during rollout so nothing breaks while you migrate each
# integration to a first-class OIDC client. Default: false.
# OIDC_ALLOW_SHARED_KEY_FALLBACK=true

# Role mapping — Azure AD security group Object ID → Gen Pulse role.
# Multiple mappings allowed. The suffix after OIDC_ROLE_MAP_ is arbitrary
# (comment for humans); the value must be "<group-guid>=<role>".
# Supported roles: member, manager, director, admin.
# OIDC_ROLE_MAP_CSM_TEAM=11111111-2222-3333-4444-555555555555=member
# OIDC_ROLE_MAP_CSM_MANAGERS=66666666-7777-8888-9999-aaaaaaaaaaaa=manager
# OIDC_ROLE_MAP_CSM_DIRECTORS=bbbbbbbb-cccc-dddd-eeee-ffffffffffff=director
# OIDC_ROLE_MAP_PULSE_ADMINS=00000000-1111-2222-3333-444444444444=admin

# =====================================================================
# MOCK-OIDC (demo / pre-prod only)
# =====================================================================
# When AUTH_STRATEGY=mock-oidc, Gen Pulse skips Azure entirely and
# serves a local HTML sign-in form at /auth/login that issues the SAME
# session-cookie format as real OIDC. This lets the signed-in UI
# (avatar, roles, session badge, /api/me) be demoed end-to-end BEFORE
# Azure AD app registration is approved.
#
# CRITICAL: This mode bypasses all real authentication. It MUST NEVER
# be enabled in production. Two guardrails protect against accidental
# enablement:
#   1. OIDC_MOCK_ALLOW=true must be set explicitly (below).
#   2. A loud [auth] warning is printed on boot whenever mock mode
#      activates, including the process PID.
#
# To switch to real Azure AD: flip AUTH_STRATEGY back to `oidc`,
# comment out OIDC_MOCK_* lines, uncomment the OIDC_TENANT_ID /
# OIDC_CLIENT_ID / OIDC_CLIENT_SECRET lines above. The UI / client
# code does not change — mock and real sessions share the same shape.
# =====================================================================
# AUTH_STRATEGY=mock-oidc
# OIDC_MOCK_ALLOW=true

# Default identity pre-filled into the demo sign-in form. Lets the
# exec rehearsal be a single "Sign in" click rather than typing a
# name + email every time. All three values are still editable in
# the form — these are only defaults.
# OIDC_MOCK_DEFAULT_NAME=Kevin Mold
# OIDC_MOCK_DEFAULT_EMAIL=kevin.mold@gendigital.com
# OIDC_MOCK_DEFAULT_ROLES=manager
