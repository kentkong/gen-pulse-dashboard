# Slack app credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Dev without public HTTPS: set SLACK_SOCKET_MODE=true and create an App-Level Token with connections:write
# SLACK_SOCKET_MODE=true
# SLACK_APP_TOKEN=xapp-your-app-token

# Optional: comma-separated Slack user IDs who can start roll calls and run admin reports
# (If empty, anyone in the workspace can use admin commands — fine for small teams only.)
TEAMPRESENCE_ADMIN_USER_IDS=U01234567,U07654321

# Public base URL of this service (no trailing slash). Used in Slack interactivity URLs if you add OAuth later.
# Example: https://presence.example.com
PUBLIC_URL=https://your-domain.example

# SQLite path (default: ./data/teampresence.db)
DATABASE_PATH=./data/teampresence.db

# Optional: default channel ID for daily digest (C...)
# TEAMPRESENCE_DIGEST_CHANNEL_ID=

# ---- EMAIL NORTON dashboard ----

# Brand name shown in the dashboard header and some Slack responses.
BRAND_NAME=EMAIL NORTON

# IANA timezone used to compute "today" for daily check-ins.
TEAM_TIMEZONE=Europe/Prague

# Slack channel ID that receives exception alerts (late / sick / pto / away / ooo / rollcall late/absent).
# Invite the bot to this channel. Leave empty to disable alerts.
# BOSS_CHANNEL_ID=C0123456789

# Shared secret required to view the web dashboard at /?key=…
# Leave empty ONLY for local dev.
# DASHBOARD_KEY=change-me-to-something-long

# Optional: comma-separated Slack user IDs that should always appear on the dashboard
# even before anyone has used a slash command.
# TEAM_MEMBER_IDS=U01234567,U07654321

# ---- Role gating for dashboard widgets (v1) ----
# Each user's roles = the union of lists they appear in. Widgets declare which
# roles may see them (manifest in src/widgets.js).
# ROLE_EMAIL_USER_IDS=U01234567,U07654321
# ROLE_CSM_USER_IDS=
# ROLE_MANAGER_USER_IDS=
# ROLE_DEV_USER_IDS=
# ROLE_TARGETING_USER_IDS=

# ---- Norton EMAIL Reports — Jira (Weekly throughput widget) ----

# Corp Jira base URL — must be reachable from wherever this service runs.
# JIRA_BASE_URL=https://jira.corp.nortonlifelock.com

# Personal Access Token from a service account (read-only is fine).
# JIRA_TOKEN=

# JQL for "issues resolved last week". The report builder injects a
# "resolved >= <startOfWeek> AND resolved < <endOfWeek>" clause on top.
# Example — narrow it to your team(s) / project(s):
# JIRA_THROUGHPUT_JQL=project = EMAIL AND statusCategory = Done

# Slack channel ID that receives the Monday 08:00 Europe/Prague throughput post.
# Invite the bot to this channel.
# REPORTS_CHANNEL_ID=C0123456789

# ---- Norton Email — Backlog Overview widget ----
# JQL describing "all open EMAIL tickets right now". The widget runs
# per-priority and per-age sub-queries on top of this base JQL.
# JIRA_BACKLOG_JQL=project = EMAIL AND statusCategory != Done

# ---- Norton Email — Average Ticket Lifecycle widget ----
# JQL describing "tickets resolved in the lookback window". The widget
# fetches created / resolutiondate / priority and computes median/mean/p95.
# JIRA_LIFECYCLE_JQL=project = EMAIL AND statusCategory = Done AND resolved >= -30d

# Optional: same query for the previous window (used to show delta vs prev period).
# JIRA_LIFECYCLE_PREV_JQL=project = EMAIL AND statusCategory = Done AND resolved >= -60d AND resolved < -30d

# How many days the lookback window covers (used only in the summary copy).
# JIRA_LIFECYCLE_LOOKBACK_DAYS=30

# ---- Norton Email — Kanban Snapshot widget ----
# JQL matching the board filter used by the team's RapidBoard
# (e.g. https://jira.corp.nortonlifelock.com/secure/RapidBoard.jspa?rapidView=101032).
# Should return the currently-visible cards — typically "not Done" + ORDER BY Rank.
# JIRA_KANBAN_JQL=project = EMOPS AND resolution = Unresolved ORDER BY Rank

# Optional: force a column order (comma-separated status names exactly as they
# appear in Jira). If unset, columns are inferred from the returned issues in
# the order Jira gives them back.
# JIRA_KANBAN_COLUMNS=To Do,In Progress,In Review,Done

# Optional: URL the "Open full board in Jira" link points at.
# JIRA_KANBAN_URL=https://jira.corp.nortonlifelock.com/secure/RapidBoard.jspa?rapidView=101032
