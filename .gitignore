# macOS
.DS_Store

# Editors
.vscode/
.idea/

# Node (apps that land here)
node_modules/
*.log

# Secrets — never commit. Use .env.example templates instead.
.env
.env.local
.env.*.local

# Local SQLite / runtime data
data/

# Local build / tmp
dist/
build/
.tmp/

# GitHub Pages publishes docs/ — explicitly opt it back in. The
# `data/` rule above would otherwise silently swallow docs/data/
# (gitignore's `name/` form matches any directory of that name
# anywhere in the tree, not just the repo root). Without this, the
# Pages site renders blank because every fetch lands a 404.
!docs/
!docs/**
